# Control plane database
DATABASE_URL=postgresql+psycopg://orchestra:orchestra@localhost:5433/orchestra

# LLM provider (all calls go through agents/shared/llm.py)
# Required for: planner --spec mode, backend-agent, frontend-agent, qa-agent.
# NOT required for: claude-code-agent (authenticates via the `claude` CLI session).
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Service URLs
ORCHESTRATOR_URL=http://localhost:8080
GATEWAY_URL=http://localhost:8081
CAPABILITY_SECRET=change-me-generate-with-python-secrets-token-hex-32

# Redis Streams event bus (Phase 2+)
REDIS_URL=redis://localhost:6380

# Managed sample project (artifact plane)
SANDBOX_REPO_PATH=./sandbox/sample-project
