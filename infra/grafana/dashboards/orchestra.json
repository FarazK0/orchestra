{
  "title": "Orchestra",
  "uid": "orchestra-main",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tasks by Status (24 h)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(new_status) (increase(orchestra_tasks_total_total[24h]))",
          "legendFormat": "{{new_status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "LLM Cost Today (USD)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(orchestra_task_cost_usd_total_total[24h]))",
          "legendFormat": "Cost"
        }
      ]
    },
    {
      "id": 3,
      "title": "Validator Pass Rate (1 h)",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizValue": 0,
        "maxVizValue": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(orchestra_validator_results_total_total{result=\"passed\"}[1h])) / sum(rate(orchestra_validator_results_total_total[1h]))",
          "legendFormat": "Pass rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Human Queue Latency p50 (1 h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, rate(orchestra_human_queue_latency_seconds_bucket[1h]))",
          "legendFormat": "p50 latency"
        }
      ]
    },
    {
      "id": 5,
      "title": "Human Queue Latency p95 (1 h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(orchestra_human_queue_latency_seconds_bucket[1h]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 6,
      "title": "Gateway Ops/min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total{job=\"gateway\"}[1m]) * 60",
          "legendFormat": "{{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Gateway 4xx/min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total{job=\"gateway\",status_code=~\"4..\"}[1m]) * 60",
          "legendFormat": "{{handler}} {{status_code}}"
        }
      ]
    }
  ]
}
